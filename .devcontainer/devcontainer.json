{
  "name": "Maxim Broadcast Demo",
  "build": {
    "dockerfile": "Dockerfile",
    "context": ".."
  },
  "forwardPorts": [4000, 3000],
  "portsAttributes": {
    "4000": {
      "label": "Maxim Broadcast App",
      "onAutoForward": "openBrowser",
      "visibility": "public"
    },
    "3000": {
      "label": "Frontend Dev Server",
      "onAutoForward": "notify",
      "visibility": "public"
    }
  },
  "postCreateCommand": "bash scripts/setup-codespace.sh",
  "remoteEnv": {
    "NODE_ENV": "production",
    "PORT": "4000",
    "JWT_SECRET": "demo-secret-key-only-not-for-production",
    "DB_TYPE": "sqlite",
    "DB_PATH": "./db/demo.db",
    "DEMO_MODE": "true",
    "CODESPACE_MODE": "true",
    "LOG_LEVEL": "info"
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "dbaeumer.vscode-eslint",
        "esbenp.prettier-vscode",
        "bradlc.vscode-tailwindcss",
        "ms-vscode.js-debug"
      ],
      "settings": {
        "editor.formatOnSave": true,
        "editor.defaultFormatter": "esbenp.prettier-vscode",
        "terminal.integrated.defaultProfile.linux": "bash"
      }
    }
  },
  "features": {
    "ghcr.io/devcontainers/features/git:1": {}
  }
}
