# Maxim Broadcast Server
PORT=4000
NODE_ENV=production
FRONTEND_URL=*
LOG_LEVEL=info

# Auth
JWT_SECRET=change-this-to-a-random-secret

# OBS WebSocket (obs-websocket v5 — built into OBS 28+)
# Leave empty to start in standalone mode
OBS_WS_HOST=localhost
OBS_WS_PORT=4455
OBS_WS_PASSWORD=your-obs-websocket-password

# Storage
MEDIA_STORAGE_PATH=./uploads/media
AUDIO_PATH=./uploads/audio
RECORDINGS_PATH=./recordings
