# ─── Maxim Broadcast — Environment Variables ─────────────────────────────────
# Copy this file to .env and fill in the values.
# On Railway, set these in the "Variables" tab of your service.

NODE_ENV=production
PORT=4000
HOST=0.0.0.0

# ─── Auth ─────────────────────────────────────────────────────────────────────
# REQUIRED: Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your-secret-key-here-replace-this
JWT_EXPIRY=30d

# ─── Database ─────────────────────────────────────────────────────────────────
# SQLite (default — works on Railway free tier)
DB_TYPE=sqlite
DB_PATH=./db/maxim.db

# Optional: PostgreSQL (upgrade path)
# DATABASE_URL=postgresql://user:pass@host:5432/maxim

# ─── Frontend / CORS ──────────────────────────────────────────────────────────
# Set to your Railway public URL after first deploy
FRONTEND_URL=https://your-railway-url.railway.app
CORS_ORIGIN=https://your-railway-url.railway.app

# ─── OBS WebSocket (optional — leave empty for standalone/demo mode) ──────────
OBS_WS_HOST=
OBS_WS_PORT=4455
OBS_WS_PASSWORD=

# ─── Storage ──────────────────────────────────────────────────────────────────
MEDIA_STORAGE_PATH=./uploads/media
AUDIO_PATH=./uploads/audio
RECORDINGS_PATH=./recordings

# ─── Features ─────────────────────────────────────────────────────────────────
ENABLE_RADIOSYNC=true
ENABLE_AI_FEATURES=true
DEMO_MODE=false

# ─── Logging ──────────────────────────────────────────────────────────────────
LOG_LEVEL=info
